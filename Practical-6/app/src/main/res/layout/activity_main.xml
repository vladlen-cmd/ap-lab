<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Broadcast Receiver Demo"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Listening for Power Connected / Disconnected broadcasts"
        android:textAlignment="center"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:background="#E8F5E9"
        android:padding="16dp"
        android:text="Status: Waiting for broadcast..."
        android:textAlignment="center"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnSendCustomBroadcast"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Send Custom Broadcast" />

    <TextView
        android:id="@+id/tvCustomStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="#E3F2FD"
        android:padding="16dp"
        android:text="Custom Broadcast: Not received yet"
        android:textAlignment="center"
        android:textSize="18sp" />

</LinearLayout>